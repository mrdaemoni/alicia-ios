<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The Alicia backend speaks plain HTTP on a private network (home
	     Wi-Fi / Tailscale tailnet, port 8766) — never the open internet.
	     ATS would otherwise block http:// to anything but localhost. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Alicia connects to her backend on your Mac Mini over your home network or tailnet.</string>
	<!-- Background refresh polls her proactive-message feed and posts local
	     notifications; audio keeps a podcast playing when the app is
	     backgrounded. -->
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.alicia.app.refresh</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>audio</string>
	</array>
</dict>
</plist>
