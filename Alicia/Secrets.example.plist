<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Copy this file to Secrets.plist (same folder — it is gitignored)
	     and fill in your values. Without it the app runs on mock data.
	     BaseURL: where skills/ios_api.py listens — your Mac's Tailscale IP
	     or LAN hostname, port 8766.
	     Token: the ALICIA_IOS_TOKEN value from the backend's .env. -->
	<key>BaseURL</key>
	<string>http://100.x.y.z:8766</string>
	<key>Token</key>
	<string>paste-ALICIA_IOS_TOKEN-here</string>
</dict>
</plist>
